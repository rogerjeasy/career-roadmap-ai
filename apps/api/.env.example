# ── Application ────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
# Override log format: "json" forces structured output even in dev
# (set to "json" when running make obs-up so logs appear in Loki)
# LOG_FORMAT=json

# ── Server ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ───────────────────────────────────────────────
# Browser page origins allowed by FastAPI's CORSMiddleware (defense-in-depth layer).
# Kong is the primary CORS handler. FastAPI only needs the real browser page origin —
# the URL the user navigates to in their browser (Next.js dev server).
# NEVER add the API server URL or gateway URL here (those are server addresses, not page origins).
# pydantic-settings v2 JSON-parses list fields before validators run.
# Value MUST be a JSON array — not a plain string or comma-separated list.
# Dev:        CORS_ORIGINS=["http://localhost:3000"]
# Production: CORS_ORIGINS=["https://app.your-domain.com"]
CORS_ORIGINS=["http://localhost:3000"]

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://crai:crai_dev_password@localhost:5432/career_roadmap
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ──────────────────────────────────────────────
# Redis database assignment:
#   DB 0 → FastAPI sessions (this URL)
#   DB 1 → Celery broker
#   DB 2 → Celery results
#   DB 8 → All MCP server response caches (MCP_REDIS_URL above)
#   DB 9 → Kong rate-limiting        (hardcoded in apps/api/kong/kong.dev.yml)
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=86400
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Shared Redis DB for all MCP server response caches (keys: mcp:cache:<tool>:<hash>)
MCP_REDIS_URL=redis://localhost:6379/8

# ── Firebase Auth ──────────────────────────────────────
# Get project ID from Firebase Console → Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to service account JSON downloaded from Firebase Console → Service accounts
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# OR paste the entire JSON as a single-line string (for CI / cloud deployments)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
# Web API Key — Firebase Console → Project Settings → General → Web API Key
# Required for server-side email/password login and token refresh
FIREBASE_WEB_API_KEY=AIzaSy...

# ── Admin ──────────────────────────────────────────────
# Protects POST /admin/kb/ingest. Must be set in production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# ── External data sources (KB enrichment) ──────────────
# BLS Public Data API v2 key — register free at https://data.bls.gov/registrationEngine/
# Optional: raises daily request limit from 25 → 500 for employment projections.
BLS_API_KEY=

# O*NET Web Services API — register free at https://services.onetcenter.org/developer/
# Enriches career KB with structured tasks, technology skills, and occupation descriptions.
# Both username and password required; leave blank to skip O*NET enrichment.
ONET_USERNAME=
ONET_PASSWORD=

# Adzuna Jobs API — register free at https://developer.adzuna.com/
# Adds live EU job counts + advertised salaries to swiss_eu_market data.
# Free tier: 100 req/day. Both values required; leave blank to skip.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Stack Exchange API key — register free at https://stackapps.com/apps/oauth/register
# Raises quota from 300 req/day → 10,000/day for market trend data collection.
# Optional: leave blank to use unauthenticated (300/day is enough for occasional runs).
SE_API_KEY=

# ── API Gateway (Kong) ─────────────────────────────────
# Kong is the single entry point for all external traffic.
# FastAPI does NOT read these at runtime — they are for developer tooling
# (make gateway-admin, make deck-diff, make deck-sync).
#
# Start Kong: make gateway-up
KONG_PROXY_URL=http://localhost:8080
KONG_ADMIN_URL=http://localhost:8001

# ── Rate limiting ──────────────────────────────────────
# FastAPI app-level rate limit (per user, applied after Kong's per-IP limit).
# Kong also enforces 60 req/min per IP globally (configured in kong.dev.yml).
RATE_LIMIT_PER_MINUTE=60

# ── LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# ── Observability ──────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_SEND_DEFAULT_PII=false
PROMETHEUS_METRICS_ENABLED=true
# OTel tracing — disabled by default; enable when the observability stack is up.
# Start the stack: make gateway-obs-up
# Then flip both vars:
OTEL_TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=career-roadmap-api
# Celery workers push agent/LLM/MCP metrics to this URL (requires observability stack).
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091

# ── Storage ────────────────────────────────────────────
# Document Store MCP server provider: local | azure | cloudinary
BLOB_STORAGE_PROVIDER=cloudinary
BLOB_STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=10

# ── Agent — LLM model overrides ────────────────────────
ORCHESTRATOR_MODEL=claude-sonnet-4-6
CLARIFICATION_MODEL=claude-sonnet-4-6
VALIDATOR_MODEL=claude-haiku-4-5-20251001
MARKET_INTELLIGENCE_MODEL=claude-haiku-4-5-20251001
ROADMAP_GENERATION_MODEL=claude-sonnet-4-6
ROADMAP_MILESTONE_MODEL=claude-haiku-4-5-20251001
COACH_MODEL=claude-haiku-4-5-20251001
OPPORTUNITY_MODEL=claude-sonnet-4-6
NETWORKING_MODEL=claude-haiku-4-5-20251001

# ── Agent — orchestrator tuning ────────────────────────
COMPLETENESS_THRESHOLD=0.75
MAX_CLARIFICATION_ROUNDS=3
MAX_CLARIFICATION_QUESTIONS=3
AGENT_TASK_TIMEOUT_SECONDS=120
ORCHESTRATOR_MAX_ITERATIONS=15

# ── Agent — pipeline tuning ────────────────────────────
LEARNING_RESOURCES_MAX_GAPS=10
NETWORKING_MAX_OUTREACH_DRAFTS=3
NETWORKING_MAX_EVENTS=10
EVENT_CHANNEL_TTL_SECONDS=3600

# ── MCP server endpoints ───────────────────────────────
# Agents call MCP servers DIRECTLY (internal service-to-service, not via Kong).
# Kong only routes /mcp/** for external clients; agents use these URLs instead.
# Leave blank to use StubMCPClient (no real data, safe for local dev without MCP servers).
# Set to the local port when running the MCP server: e.g. http://localhost:3001
MCP_JOB_BOARD_URL=
MCP_SALARY_BENCHMARK_URL=
MCP_GITHUB_TRENDS_URL=
MCP_SOCIAL_SIGNALS_URL=
MCP_COURSE_CATALOG_URL=
MCP_LINKEDIN_PROFILE_URL=
MCP_INDUSTRY_NEWS_URL=
MCP_CALENDAR_URL=
MCP_TIMEOUT_SECONDS=30.0
# Shared bearer token sent by agents to all MCP servers (must match MCP_API_KEY on each server).
MCP_API_TOKEN=

# ── MCP server — shared auth key ──────────────────────
# Set on each MCP server process. Leave blank to disable auth (dev only).
MCP_API_KEY=

# ── MCP — Job Board API keys (RapidAPI) ───────────────
LINKEDIN_API_KEY=
INDEED_API_KEY=
GLASSDOOR_API_KEY=

# ── MCP — Course Catalogue API keys ───────────────────
COURSERA_API_KEY=
UDEMY_API_KEY=
YOUTUBE_API_KEY=
OREILLY_API_KEY=

# ── MCP — Social Signals API keys ─────────────────────
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
DEVTO_API_KEY=

# ── MCP — Salary Benchmark API keys ───────────────────
# Glassdoor via RapidAPI — same key as GLASSDOOR_API_KEY above (shared)
# levels.fyi client uses no key (unofficial API, rate-limited by design)

# ── MCP — GitHub Trends ───────────────────────────────
# Optional but highly recommended: raises rate limit from 60 → 5000 req/hr
# Generate at: https://github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=

# ── MCP — Industry News ───────────────────────────────
# NewsAPI.org — free developer plan: 100 req/day
# Sign up at: https://newsapi.org/register
# RSS feeds are always active (no key required)
NEWSAPI_KEY=

# ── RAG — Pinecone + embeddings ───────────────────────
RAG_ENABLED=true
PINECONE_API_KEY=
PINECONE_INDEX_NAME=career-roadmap-kb-hybrid
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=3072
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BATCH_SIZE=100
RAG_TOP_K=10
RAG_MIN_SCORE=0.65

# ── RAG — hybrid search (dense + BM25) ────────────────
HYBRID_SEARCH_ENABLED=true
HYBRID_ALPHA=0.75
BM25_ENCODER_PATH=

# ── RAG — reranker ────────────────────────────────────
RERANKER_ENABLED=true
RERANKER_TYPE=cross_encoder
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=20
# COHERE_API_KEY=    # only needed when RERANKER_TYPE=cohere

# ── RAG — MMR diversity filter ────────────────────────
MMR_ENABLED=true
MMR_LAMBDA=0.5
FETCH_K_MULTIPLIER=3

# ── RAG — context injection ───────────────────────────
CONTEXT_INJECTION_TOKEN_BUDGET=4000
MARKET_DATA_FRESHNESS_DAYS=30
STALE_MARKET_DATA_EXCLUDED=true

# ── Cloudinary (document storage) ─────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=career-roadmap

# ── Firestore roadmap persistence (agent worker) ───────
# Enables durable storage of generated roadmaps to Firestore.
# The agent worker uses google-cloud-firestore directly (no firebase_admin).
# FIREBASE_PROJECT_ID and credentials are shared with the API — set them once.
FIRESTORE_PERSISTENCE_ENABLED=false
# FIREBASE_PROJECT_ID is already set above in the Firebase Auth section.
# Credentials are read from FIREBASE_CREDENTIALS_PATH / FIREBASE_CREDENTIALS_JSON
# (same vars as API). If neither is set, Application Default Credentials are used.

# ── Celery Beat — KB data directory ───────────────────
# Absolute path to seed files directory. Leave blank for the default.
KB_DATA_DIR=

# ── OAuth integrations (LinkedIn / GitHub / Google Calendar) ──
# Where the browser returns after an OAuth callback completes (the web app).
FRONTEND_BASE_URL=http://localhost:3000
# Public base URL of THIS API — used to build provider redirect_uri values.
# Must match the callback URL registered in each provider's OAuth app:
#   {OAUTH_CALLBACK_BASE_URL}/api/v1/integrations/{provider}/callback
OAUTH_CALLBACK_BASE_URL=http://localhost:8000
# Fernet key for encrypting stored OAuth tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without it, connecting an external account is refused.
INTEGRATION_TOKEN_KEY=
# Per-provider OAuth client credentials. A provider only becomes connectable
# once BOTH its id and secret are set.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
