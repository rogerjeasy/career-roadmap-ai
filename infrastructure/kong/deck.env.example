# ─────────────────────────────────────────────────────────────────────────────
# deck environment variables for Kong production config sync.
#
# Copy to .env.production and fill in real values. Never commit .env.production.
#
# Usage:
#   deck sync \
#     --state infrastructure/kong/kong.yml \
#     --env-file infrastructure/kong/.env.production \
#     --kong-addr https://<kong-admin-url>
#
# To diff without applying:
#   deck diff \
#     --state infrastructure/kong/kong.yml \
#     --env-file infrastructure/kong/.env.production
# ─────────────────────────────────────────────────────────────────────────────

# ── Upstreams ──────────────────────────────────────────────────────────────
# Internal Container Apps DNS (no port needed when using default HTTP 80).
FASTAPI_UPSTREAM_HOST=fastapi-api
FASTAPI_UPSTREAM_PORT=8000

MCP_JOB_BOARD_HOST=mcp-job-board
MCP_COURSE_CATALOGUE_HOST=mcp-course-catalogue
MCP_GITHUB_TRENDS_HOST=mcp-github-trends
MCP_SALARY_BENCHMARK_HOST=mcp-salary-benchmark
MCP_SOCIAL_SIGNALS_HOST=mcp-social-signals
MCP_CALENDAR_HOST=mcp-calendar
MCP_INDUSTRY_NEWS_HOST=mcp-industry-news

# ── Redis (Azure Cache for Redis) ──────────────────────────────────────────
REDIS_HOST=<your-redis-name>.redis.cache.windows.net
REDIS_PORT=6380

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN_FRONTEND=https://app.career-roadmap.example.com

# ── OpenTelemetry ──────────────────────────────────────────────────────────
OTEL_ENDPOINT=<your-tempo-or-collector-host>
ENVIRONMENT=production
