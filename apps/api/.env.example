# ── Application ────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://crai:crai_dev_password@localhost:5432/career_roadmap
DB_ECHO=false

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-me-with-a-real-secret-on-first-setup

# ── LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=

# ── Observability ──────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_SEND_DEFAULT_PII=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=career-roadmap-api

# ── Storage ────────────────────────────────────────────
BLOB_STORAGE_PROVIDER=local
BLOB_STORAGE_PATH=./storage