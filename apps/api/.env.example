# ── Application ────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://crai:crai_dev_password@localhost:5432/career_roadmap
DB_ECHO=false

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Firebase Auth ──────────────────────────────────────
# Get project ID from Firebase Console → Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to service account JSON downloaded from Firebase Console → Service accounts
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# OR paste the entire JSON as a single-line string (for CI / cloud deployments)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
# Web API Key — Firebase Console → Project Settings → General → Web API Key
# Required for server-side email/password login and token refresh
FIREBASE_WEB_API_KEY=AIzaSy...

# ── Rate limiting ──────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=

# ── Observability ──────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_SEND_DEFAULT_PII=false
# Leave blank in dev to disable trace export (no Jaeger/Tempo running locally)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=career-roadmap-api

# ── Storage ────────────────────────────────────────────
BLOB_STORAGE_PROVIDER=local
BLOB_STORAGE_PATH=./storage